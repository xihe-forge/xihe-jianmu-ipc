# Hub configuration — copy this file to .env and fill in your values
# cp .env.example .env

# Hub port (default: 3179)
IPC_PORT=3179

# OpenClaw Gateway URL (required for delivering messages to OpenClaw sessions)
OPENCLAW_URL=http://127.0.0.1:18789

# OpenClaw Gateway hooks token (required — get from your OpenClaw config: hooks.token)
OPENCLAW_TOKEN=your-openclaw-hooks-token-here
