{
  "name": "xihe-jianmu-ipc",
  "version": "0.2.0",
  "description": "建木 — Real-time IPC hub for multi-AI-agent communication. WebSocket message routing between Claude Code, OpenClaw, Codex, and any HTTP client.",
  "type": "module",
  "main": "hub.mjs",
  "bin": {
    "jianmu": "./bin/jianmu.mjs"
  },
  "files": [
    "hub.mjs",
    "mcp-server.mjs",
    "lib/",
    "bin/jianmu.mjs",
    "bin/install.ps1",
    "bin/patch-channels.mjs",
    "CLAUDE.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "ipc",
    "multi-agent",
    "claude-code",
    "openclaw",
    "codex",
    "mcp",
    "websocket",
    "ai-collaboration",
    "xihe",
    "jianmu"
  ],
  "author": "xihe-forge <xihe-ai@lumidrivetech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xihe-forge/xihe-jianmu-ipc"
  },
  "homepage": "https://github.com/xihe-forge/xihe-jianmu-ipc",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "ws": "^8.18.0"
  },
  "scripts": {
    "hub": "node hub.mjs",
    "test": "node --test --test-isolation=none --test-force-exit tests/*.test.mjs tests/integration/*.test.mjs tests/e2e/*.test.mjs",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "status": "pm2 status",
    "logs": "pm2 logs --lines 50"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1"
  }
}
