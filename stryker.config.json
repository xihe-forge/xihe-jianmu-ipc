{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "node --test --test-force-exit tests/*.test.mjs tests/integration/*.test.mjs"
  },
  "mutate": [
    "lib/router.mjs",
    "lib/protocol.mjs",
    "lib/redact.mjs",
    "lib/command-parser.mjs"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "concurrency": 2,
  "reporters": ["clear-text"],
  "coverageAnalysis": "off",
  "tempDirName": ".stryker-tmp",
  "timeoutMS": 60000,
  "dryRunTimeoutMinutes": 3
}
