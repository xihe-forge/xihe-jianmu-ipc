{
  "name": "xihe-jianmu-ipc",
  "version": "0.5.0",
  "description": "建木 — Real-time IPC hub for multi-AI-agent communication. WebSocket message routing between Claude Code, OpenClaw, Codex, and any HTTP client.",
  "type": "module",
  "main": "hub.mjs",
  "bin": {
    "jianmu": "bin/jianmu.mjs"
  },
  "files": [
    "hub.mjs",
    "mcp-server.mjs",
    "lib/",
    "docs/",
    "bin/jianmu.mjs",
    "bin/claude-stdin-auto-accept.mjs",
    "bin/network-watchdog.mjs",
    "bin/install.ps1",
    "bin/patch-channels.mjs",
    "bin/hub-daemon.vbs",
    "bin/install-daemon.ps1",
    "bin/uninstall-daemon.ps1",
    "bin/verify-daemons.ps1",
    "bin/cliproxy-daemon.vbs",
    "bin/install-cliproxy-daemon.ps1",
    "bin/uninstall-cliproxy-daemon.ps1",
    "bin/network-watchdog-daemon.vbs",
    "bin/install-network-watchdog-daemon.ps1",
    "bin/uninstall-network-watchdog-daemon.ps1",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "ipc",
    "multi-agent",
    "claude-code",
    "openclaw",
    "codex",
    "mcp",
    "websocket",
    "ai-collaboration",
    "xihe",
    "jianmu"
  ],
  "author": "xihe-forge <xihe-ai@lumidrivetech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xihe-forge/xihe-jianmu-ipc.git"
  },
  "homepage": "https://github.com/xihe-forge/xihe-jianmu-ipc",
  "dependencies": {
    "@ccusage/codex": "18.0.11",
    "@ccusage/mcp": "18.0.11",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.8.0",
    "ccusage": "18.0.11",
    "ws": "^8.18.0"
  },
  "overrides": {
    "axios": "1.15.0"
  },
  "scripts": {
    "postinstall": "powershell -ExecutionPolicy Bypass -File bin/install.ps1 || true",
    "hub": "node hub.mjs",
    "test": "node bin/run-tests.mjs tests tests/integration tests/e2e",
    "test:unit": "node bin/run-tests.mjs tests",
    "test:integration": "node bin/run-tests.mjs tests/integration",
    "test:e2e": "node bin/run-tests.mjs tests/e2e",
    "test:mutation": "stryker run",
    "status": "node bin/jianmu.mjs status",
    "watchdog": "node bin/network-watchdog.mjs",
    "logs": "tail -n 50 data/hub.log",
    "daemon:install": "powershell -ExecutionPolicy Bypass -File bin/install-daemon.ps1",
    "daemon:uninstall": "powershell -ExecutionPolicy Bypass -File bin/uninstall-daemon.ps1",
    "daemon:verify": "powershell -ExecutionPolicy Bypass -File bin/verify-daemons.ps1",
    "daemon:watchdog:install": "powershell -File bin/install-network-watchdog-daemon.ps1",
    "daemon:watchdog:uninstall": "powershell -File bin/uninstall-network-watchdog-daemon.ps1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1"
  }
}
