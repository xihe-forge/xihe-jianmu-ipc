{
  "name": "xihe-jianmu-ipc",
  "version": "0.3.0",
  "description": "建木 — Real-time IPC hub for multi-AI-agent communication. WebSocket message routing between Claude Code, OpenClaw, Codex, and any HTTP client.",
  "type": "module",
  "main": "hub.mjs",
  "bin": {
    "jianmu": "bin/jianmu.mjs"
  },
  "files": [
    "hub.mjs",
    "mcp-server.mjs",
    "lib/",
    "bin/jianmu.mjs",
    "bin/install.ps1",
    "bin/patch-channels.mjs",
    "CLAUDE.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "ipc",
    "multi-agent",
    "claude-code",
    "openclaw",
    "codex",
    "mcp",
    "websocket",
    "ai-collaboration",
    "xihe",
    "jianmu"
  ],
  "author": "xihe-forge <xihe-ai@lumidrivetech.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xihe-forge/xihe-jianmu-ipc.git"
  },
  "homepage": "https://github.com/xihe-forge/xihe-jianmu-ipc",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "ws": "^8.18.0"
  },
  "overrides": {
    "axios": "1.15.0"
  },
  "scripts": {
    "hub": "node hub.mjs",
    "test": "node --test --test-force-exit tests/*.test.mjs tests/integration/*.test.mjs tests/e2e/*.test.mjs",
    "test:unit": "node --test --test-force-exit tests/*.test.mjs",
    "test:integration": "node --test --test-force-exit tests/integration/*.test.mjs",
    "test:e2e": "node --test --test-force-exit tests/e2e/*.test.mjs",
    "test:mutation": "stryker run",
    "status": "node bin/jianmu.mjs status",
    "logs": "tail -n 50 data/hub.log",
    "daemon:install": "powershell -ExecutionPolicy Bypass -File bin/install-daemon.ps1",
    "daemon:uninstall": "powershell -ExecutionPolicy Bypass -File bin/uninstall-daemon.ps1",
    "daemon:verify": "powershell -ExecutionPolicy Bypass -File bin/verify-daemons.ps1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1"
  }
}
