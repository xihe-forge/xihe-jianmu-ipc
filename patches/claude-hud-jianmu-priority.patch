+async function fetchUsageApiWithJianmu(_accessToken: string): Promise<UsageApiResult> {
+  const jianmuResult = await fetchJianmuUsageApi();
+  if (jianmuResult.data) {
+    return jianmuResult;
+  }
+
+  debug('Jianmu usage unavailable, direct Anthropic fallback suppressed:', jianmuResult.error);
+  return jianmuResult;
+}
+
+function fetchJianmuUsageApi(): Promise<UsageApiResult> {
+  return new Promise((resolve) => {
+    const req = http.request(
+      {
+        hostname: '127.0.0.1',
+        port: 3179,
+        path: '/usage',
+        method: 'GET',
+        timeout: JIANMU_USAGE_TIMEOUT_MS,
+      },
+      (res) => {
+        let data = '';
+
+        res.on('data', (chunk: Buffer) => {
+          data += chunk.toString();
+        });
+
+        res.on('end', () => {
+          if (res.statusCode !== 200) {
+            resolve({
+              data: null,
+              error: res.statusCode ? `jianmu-http-${res.statusCode}` : 'jianmu-http-error',
+            });
+            return;
+          }
+
+          try {
+            const parsed = JSON.parse(data);
+            if (parsed?.ok !== true) {
+              resolve({ data: null, error: 'jianmu-failure' });
+              return;
+            }
+
+            resolve({
+              data: {
+                five_hour: parsed.five_hour,
+                seven_day: parsed.seven_day,
+              },
+              source: 'jianmu',
+            });
+          } catch {
+            resolve({ data: null, error: 'jianmu-parse' });
+          }
+        });
+      }
+    );
+
+    req.on('error', () => {
+      resolve({ data: null, error: 'jianmu-network' });
+    });
+    req.on('timeout', () => {
+      req.destroy();
+      resolve({ data: null, error: 'jianmu-timeout' });
+    });
+
+    req.end();
+  });
+}
